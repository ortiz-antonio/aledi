---
import data from '../content/landing.json'
---

<section class="grid grid-cols-3">
  <div class="col-span-1">
    <img src={data.example.imageFinished} alt={data.example.imageFinishedAlt} />
  </div>
  <div class="col-span-2">
    <h1 class="text-step-1">{data.hero.title}</h1>
    <p>
      {data.hero.text}
      <br />
      {data.example.title}
      <span class="inline-block text-right m-0 p-0"
        ><img src={data.example.imageSketch} alt={data.example.imageSketchAlt} />
      </span>
    </p>

    <div>
      <p>{data.footer.title}</p>
      <p>{data.footer.text}</p>
    </div>
    <div>
      <p>{data.english.title}</p>
      <p>{data.english.text}</p>
    </div>
    <div class="block">
      <a href={data.redes.fb} class="ui-button">Facebook</a>
      <a href={data.redes.instagram} class="ui-button">Instagram</a>
      <a href={data.redes.blog} class="ui-button-small">Blog</a>
      <a href={data.redes.portafolio} class="ui-button">Portafolio</a>
    </div>
  </div>
</section>
