---
import type { HeroData } from '../types'
import HeroSvg from './svgs/HeroSvg.astro'

const { data } = Astro.props as { data: HeroData }
---

<section class="ui-section ui-section-odd">
  <div class="ui-section-container flow">
    <div class="lg:grid lg:cols-3 lg:items-center lg:gap-xl flow">
      <div class="lg:col-span-2 flow">
        <h1 class="ui-text-title-1">{data.title}</h1>
        <p class="ui-text-base">{data.text}</p>
      </div>
      <div class="lg:col-span-1 flex place-content-center block">
        <HeroSvg class="color-foreground" label={data.imageAlt} />
      </div>
    </div>

    <a class="ui-button inline-block p-s" href="#">{data.cta}</a>
    <p class="ui-text-sm">{data.ctaCopy}</p>
  </div>
</section>
